#!/bin/sh

# Ensure we use the global PHP version to prevent issues from running this script from an isolated
# directory, which then affects the global composer requirements etc.
USE_GLOBAL_PHP=1

echo "\n > Upgrading brew packages...\n"
brew update
brew upgrade
# Fixes gnupg link conflicts with GPGSuite
brew unlink gnupg

# Link libpq to access psql
brew link --force libpq

# Update global tools e.g. pnpm, bun, node etc..
proto outdated -c global --update --yes
proto install -c global

echo "\n > Upgrading global composer packages...\n"
composer global upgrade

echo "\n > Running valet install...\n"
valet install

echo "\n > Installing nvim packages from lockfile...\n"
nvim --headless "+Lazy! restore" +qa

echo "\n > Upgrading znap plugins...\n"
znap-update
echo "\n"

echo "\n > Done 🚀 enjoy your day!\n"
